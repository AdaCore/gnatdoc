  <h3>Inherited dispatching subprograms</h3>

  <ul>
    <li tal:repeat='subprogram gnatdoc/entity/inherited_dispatching_subprograms'>
      <!--
      <a tal:condition='subprogram/is_documented' tal:attributes='href subprogram/full_href' tal:content='subprogram/name'>SUBPROGRAM NAME</a>
      <span tal:condition='not:subprogram/is_documented' tal:content='subprogram/name'>SUBPROGRAM NAME</span>
      -->
      <span tal:content='subprogram/name'>SUBPROGRAM NAME</span>
    </li>
  </ul>
</div>

