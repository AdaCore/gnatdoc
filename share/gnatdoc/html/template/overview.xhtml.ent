
<p tal:condition='exists:gnatdoc/entity/parent_type' xml:space='preserve'>Parent type:
  <a tal:condition='gnatdoc/entity/parent_type/is_documented' tal:attributes='href gnatdoc/entity/parent_type/full_href' tal:content='gnatdoc/entity/parent_type/name'>PARENT TYPE NAME</a>
  <span tal:condition='not:gnatdoc/entity/parent_type/is_documented' tal:content='gnatdoc/entity/parent_type/name'>PARENT TYPE NAME</span>
</p>

<p tal:condition='exists:gnatdoc/entity/progenitor_types' xml:space='preserve'>Progenitor types:
  <div tal:omit-tag='' tal:repeat='progenitor gnatdoc/entity/progenitor_types'>
    <a tal:condition='progenitor/is_documented' tal:attributes='href progenitor/full_href' tal:content='progenitor/name'>PROGENIOTOR TYPE NAME</a>
    <span tal:condition='not:progenitor/is_documented' tal:content='progenitor/name'>PROGENITOR TYPE NAME</span>
  </div>
</p>

<p tal:condition='exists:gnatdoc/entity/derived_types' xml:space='preserve'>Derived types:
  <div tal:omit-tag='' tal:repeat='derived gnatdoc/entity/derived_types'>
    <a tal:condition='derived/is_documented' tal:attributes='href derived/full_href' tal:content='derived/name'>DERIVED TYPE NAME</a>
    <span tal:condition='not:derived/is_documented' tal:content='derived/name'>DERIVED TYPE NAME</span>
  </div>
</p>

<p tal:condition='exists:gnatdoc/entity/all_parent_types' xml:space='preserve'>All parent types:
  <div tal:omit-tag='' tal:repeat='type gnatdoc/entity/all_parent_types'>
    <a tal:condition='type/is_documented' tal:attributes='href type/full_href' tal:content='type/name'>PARENT TYPE NAME</a>
    <span tal:condition='not:type/is_documented' tal:content='type/name'>PARENT TYPE NAME</span>
  </div>
</p>

<p tal:condition='exists:gnatdoc/entity/all_progenitor_types' xml:space='preserve'>All progenitor types:
  <div tal:omit-tag='' tal:repeat='type gnatdoc/entity/all_progenitor_types'>
    <a tal:condition='type/is_documented' tal:attributes='href type/full_href' tal:content='type/name'>PARENT TYPE NAME</a>
    <span tal:condition='not:type/is_documented' tal:content='type/name'>PARENT TYPE NAME</span>
  </div>
</p>

<p tal:condition='exists:gnatdoc/entity/all_derived_types' xml:space='preserve'>All derived types:
  <div tal:omit-tag='' tal:repeat='derived gnatdoc/entity/all_derived_types'>
    <a tal:condition='derived/is_documented' tal:attributes='href derived/full_href' tal:content='derived/name'>DERIVED TYPE NAME</a>
    <span tal:condition='not:derived/is_documented' tal:content='derived/name'>DERIVED TYPE NAME</span>
  </div>
</p>

<div tal:omit-tag='' tal:condition='gnatdoc/entity/declared_dispatching_subprograms'>
  <h3>Declared dispatching subprograms</h3>

  <ul>
    <li tal:repeat='subprogram gnatdoc/entity/declared_dispatching_subprograms'>
      <a tal:condition='subprogram/is_documented' tal:attributes='href subprogram/local_href' tal:content='subprogram/name'>SUBPROGRAM NAME</a>
      <span tal:condition='not:subprogram/is_documented' tal:content='subprogram/name'>SUBPROGRAM NAME</span>
    </li>
  </ul>
</div>

<div tal:omit-tag='' tal:condition='gnatdoc/entity/overrided_dispatching_subprograms'>
