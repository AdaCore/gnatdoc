        +   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)'
        -   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)$'
      Contains Entities:
        +   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)'
        -   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)$'
      Belongs Entities:
        +   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)'
        -   Next (ADA_FUNCTION) 'p.next(() -> standard.integer)$'
  Belongs Entities:
